@model IEnumerable<HospitalManagement.Models.User>

@{
    ViewBag.Title = "Index";
}
<h2 class="user-name" style="text-align:center">User</h2>
<hr />
<p class="mt-5">
    @Html.ActionLink("Create New", "Create", null, new { @class = "btn btn-primary", style = "color:white;font-weight:600" })
</p>

<div class="container-fluid" style="overflow:auto;max-height:300px">
    <table class="table">
        <tr>
            <th class="user-name">
                @Html.DisplayNameFor(model => model.FullName)
            </th>
            <th class="user-name">
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th class="user-name">
                @Html.DisplayNameFor(model => model.UserName)
            </th>
            <th class="user-name">
                @Html.DisplayNameFor(model => model.PasswordHash)
            </th>
            <th class="user-name">
                @Html.DisplayNameFor(model => model.IsActive)
            </th>
            <th class="user-name">
                @Html.DisplayNameFor(model => model.Address)
            </th>
            <th class="user-name">
                @Html.DisplayNameFor(model => model.ProfileImagePath)
            </th>
            <th class="user-name">
                @Html.DisplayNameFor(model => model.CreatedAt)
            </th>
            <th class="user-name">Action</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td class="user-name">
                    @Html.DisplayFor(modelItem => item.FullName)
                </td>
                <td class="user-name">
                    @Html.DisplayFor(modelItem => item.Email)
                </td>
                <td class="user-name">
                    @Html.DisplayFor(modelItem => item.UserName)
                </td>
                <td class="user-name">
                    @Html.DisplayFor(modelItem => item.PasswordHash)
                </td>
                <td class="user-name">
                    @Html.DisplayFor(modelItem => item.IsActive)
                </td>
                <td class="user-name">
                    @Html.DisplayFor(modelItem => item.Address)
                </td>
                <td class="user-name">
                    @Html.DisplayFor(modelItem => item.ProfileImagePath)
                </td>
                <td class="user-name">
                    @Html.DisplayFor(modelItem => item.CreatedAt)
                </td>
                <td class="text-center gap-2" style="display:flex;">
                    <a href="@Url.Action("Edit", new { id = item.UserID })" class="btn btn-success" title="Edit">
                        <i class="fa fa-edit"></i>
                    </a>
                    <a href="@Url.Action("Details", new { id = item.UserID })" class="btn btn-secondary" title="Details">
                        <i class="fa fa-file-alt"></i>
                    </a>
                    <a href="@Url.Action("Delete", new { id = item.UserID })" class="btn btn-danger" title="Delete">
                        <i class="fa fa-trash"></i>
                    </a>
                </td>
            </tr>
        }

    </table>
</div>
