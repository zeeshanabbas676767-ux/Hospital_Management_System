@model HospitalManagement.Models.Hospital.Department

@{
    ViewBag.Title = "Delete";
}

<div>
    <h2 class="user-name" style="text-align:center">Department</h2>
    <hr />
    <h4 style="color:red">Are you sure you want to delete this?</h4>
    <dl class="dl-horizontal mt-3">
        <dt>
            @Html.DisplayNameFor(model => model.Hospital.Name)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Hospital.Name)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Name)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Name)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Description)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Description)
        </dd>

    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="mt-lg-3">
            <input type="submit" value="Delete" class="btn btn-outline-danger user-name" />
            @Html.ActionLink("Back", "Index", null, new { @class = "btn btn-outline-info user-name", style = "margin-left:10px" })
        </div>
