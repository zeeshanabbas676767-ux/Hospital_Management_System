@model HospitalManagement.Models.Billing.Invoice

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete</title>
</head>
<body>
    <div>
        <h2 class="user-name" style="text-align:center">Invoice</h2>
        <hr />
        <h4 style="color:red">Are you sure you want to delete this?</h4>
        <dl class="dl-horizontal mt-3">
            <dt>
                @Html.DisplayNameFor(model => model.Appointment.Notes)
            </dt>

            <dd>
                @Html.DisplayFor(model => model.Appointment.Notes)
            </dd>

            <dt>
                @Html.DisplayNameFor(model => model.Patient.FirstName)
            </dt>

            <dd>
                @Html.DisplayFor(model => model.Patient.FirstName)
            </dd>

            <dt>
                @Html.DisplayNameFor(model => model.CreatedAt)
            </dt>

            <dd>
                @Html.DisplayFor(model => model.CreatedAt)
            </dd>

            <dt>
                @Html.DisplayNameFor(model => model.Amount)
            </dt>

            <dd>
                @Html.DisplayFor(model => model.Amount)
            </dd>

            <dt>
                @Html.DisplayNameFor(model => model.PaymentStatus)
            </dt>

            <dd>
                @Html.DisplayFor(model => model.PaymentStatus)
            </dd>

        </dl>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="mt-lg-3">
                <input type="submit" value="Delete" class="btn btn-outline-danger user-name" />
                @Html.ActionLink("Back", "Index", null, new { @class = "btn btn-outline-info user-name", style = "margin-left:10px" })
            </div>
        }
    </div>
</body>
</html>
